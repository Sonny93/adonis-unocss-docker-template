{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["import", "node", "oxc", "react", "typescript", "unicorn"],
	"categories": {
		"correctness": "error"
	},
	"rules": {},
	"env": {
		"builtin": true,
		"node": true,
		"browser": true
	},
	"settings": {
		"react": {
			"version": "19.2"
		}
	},
	"ignorePatterns": [
		"build/**",
		"node_modules/**",
		".adonisjs/**",
		"database/schema.ts"
	]
}
